# 百炼 API Key（必填）
# 获取方式：https://dashscope.console.aliyun.com/ → API-KEY 管理 → 创建
# ⚠️ 需要支持多模态模型（qwen-vl 系列）的 API Key
#    普通文本模型 Key 仅支持 ASR 转写，视频画面理解需要多模态模型权限
#    开通方式：百炼控制台 → 模型广场 → 搜索 qwen-vl → 开通
DASHSCOPE_API_KEY=your_api_key_here

# 输出目录（首次使用时 AI 会询问并自动填入）
# 路径为相对于项目根目录的相对路径
# 所有过程文件（分析稿、工作稿、最终版、docx、截图）都存放在此目录下的子文件夹中
# 示例：OUTPUT_DIR=20_项目/小红书视频转知乎图文工具/样例
OUTPUT_DIR=
